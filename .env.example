# ────────────────────────────────────────────────────────────────────────────
# Zynd Protocol — Fair Hiring Network
# Environment variables required for deployment.
# Copy to .env (local) or set in your platform's dashboard (Render / Azure).
# ────────────────────────────────────────────────────────────────────────────

# Zynd Protocol credentials
ZYND_API_KEY=your_zynd_api_key_here
ZYND_REGISTRY_URL=https://registry.zynd.ai

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama"  → local Ollama (dev only — NOT suitable for cloud deployments)
# "openai"  → OpenAI API
# "groq"    → Groq API (recommended for production; fast + generous free tier)
LLM_PROVIDER=groq

# Groq (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BIG_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BIG_MODEL=gpt-4o
OPENAI_SMALL_MODEL=gpt-4o-mini

# Ollama (local dev only — not needed for cloud)
OLLAMA_BASE_URL=http://localhost:11434
BIG_MODEL=glm-5:cloud
SMALL_MODEL=llama3.2:3b

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# On Render: use the Internal Database URL from your Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Internal ports (used in multi-process local mode only) ───────────────────
ORCHESTRATOR_PORT=6001
SKILL_VERIFIER_PORT=6002
BIAS_DETECTOR_PORT=6003
CANDIDATE_MATCHER_PORT=6004
PRIVACY_AGENT_PORT=6005
CREDENTIAL_AGENT_PORT=6006

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is automatically set by Render/Azure — do not hardcode
# CENTRAL_PORT=8000
